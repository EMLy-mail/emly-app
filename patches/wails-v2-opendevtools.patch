+// WindowOpenDevTools opens the WebView2 DevTools window, backported from
+// Wails v3's webview_window_windows_devtools.go. Requires devtools to be
+// enabled (debug build, or frontendOptions.Debug.OpenInspectorOnStartup /
+// the F12 handler already rely on the same underlying capability).
+//
+// Bound methods run off the main thread, but the WebView2 COM object is
+// STA-affine and must only be touched from the thread that created it
+// (same reason WindowSetBackgroundColour etc. go through mainWindow.Invoke).
+func (f *Frontend) WindowOpenDevTools() {
+	f.mainWindow.Invoke(func() {
+		f.chromium.OpenDevToolsWindow()
+	})
+}
